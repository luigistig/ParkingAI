# Configuración del entorno
FLASK_ENV=development
FLASK_PORT=5000
SECRET_KEY=parqueadero-ia-2026-secret-key-change-in-production

# Base de datos
DATABASE_URL=sqlite:///parqueadero.db

# Tarifas
TARIFF_PER_HOUR=2000
MIN_CHARGE=500

# Sistema de cámara
ENABLE_CAMERA=True
CAMERA_INDEX=0

# Tesseract OCR
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
